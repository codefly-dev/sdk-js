  "bugs": {
    "url": "https://github.com/codefly-dev/sdk-js/issues"
  },
  "homepage": "https://github.com/codefly-dev/sdk-js#readme",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^25.6.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}
